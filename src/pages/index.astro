---
import Layout from 'src/modules/global/layouts/Layout.astro'
import { ToastProvider } from 'src/modules/global/components/Toast/toast'
import Hero from 'src/modules/home/components/Hero/Hero.astro'
import SectionDivider from 'src/modules/home/components/SectionDivider.astro'
import ExperienceLevels from 'src/modules/home/components/ExperienceLevels/ExperienceLevels.astro'
import CommunityValues from 'src/modules/home/components/CommunityValues/CommunityValues.astro'
import Amplify from 'src/modules/home/components/Amplify/Amplify.astro'
---

<Layout title='ShareIT - Nadie despega solo' fullWidth={true}>
  <Hero />

  <main>
    <section class='py-20 md:py-32'>
      <div class='container mx-auto px-4 max-w-5xl'>
        <ExperienceLevels />
      </div>
    </section>

    <SectionDivider />

    <section class='py-20 md:py-32 bg-gray-900/50'>
      <div class='container mx-auto px-4 max-w-5xl'>
        <CommunityValues />
      </div>
    </section>

    <SectionDivider />

    <section class='py-20 md:py-32'>
      <div class='container mx-auto px-4 max-w-5xl'>
        <Amplify />
      </div>
    </section>

    <SectionDivider />

    <section class='py-20 md:py-32 bg-gray-900/50'>
      <div class='container mx-auto px-4 max-w-5xl'>
        <div class='mb-12'>
          <h2
            class='text-4xl md:text-5xl font-bold mb-6 text-center text-white'
          >
            🚀 <span class='section-heading__accent'>Presentación</span> en Nerdearla
            <span class='text-[#7dd3fc]'>2025</span>
          </h2>
          <p
            class='text-gray-400 text-center m-auto max-w-2xl text-lg leading-relaxed'
          >
            Conoce más sobre nuestra visión como comunidad en la siguiente
            Lightning Talk que tuvo lugar durante la Nerdearla de 2025, uno de
            los eventos de tecnología más importantes de la región.
          </p>
        </div>
        <div class='flex justify-center'>
          <div class='aspect-video w-full max-w-4xl'>
            <iframe
              src='https://www.youtube.com/embed/muNVy6tuGNg'
              title='Lightning Talk de ShareIT en Nerdearla 2025 (YouTube)'
              loading='lazy'
              allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture'
              allowfullscreen
              class='rounded-2xl shadow-2xl w-full h-full border border-white/5'
            ></iframe>
          </div>
        </div>
      </div>
    </section>
  </main>

  <ToastProvider client:idle />
</Layout>
