---
import Layout from 'src/modules/global/layouts/Layout.astro'
import Events from 'src/modules/resources/components/Events.astro'
import UpcomingEventCard from 'src/modules/resources/components/UpcomingEventCard.astro'
import DiscordGroupCard from 'src/modules/community/components/DiscordGroupCard.astro'
import SectionDivider from 'src/modules/home/components/SectionDivider.astro'
import { whatsappGroups } from 'src/modules/global/constants/channels.const'
import { getGroupReferentsByIds } from 'src/modules/community/constants/group-referents.const'
import { COMMUNITY_RULES } from 'src/modules/global/constants/rules.const'
import { EVENTS } from 'src/modules/global/constants/events.const'
import { getGroupedEvents } from 'src/modules/global/utils/events.utils'

const { upcomingCommunity, pastCommunity, upcomingLearning, pastLearning } =
  getGroupedEvents(EVENTS)
---

<Layout title='Comunidad | ShareIT' fullWidth={true}>
  <section class='relative py-20 px-4 overflow-hidden'>
    <div class='max-w-4xl mx-auto relative z-10 text-center'>
      <h1
        class='text-5xl md:text-6xl font-extrabold mb-8 text-white tracking-tight'
      >
        Nuestra <span class='text-[#00e5ff]'>Comunidad</span>
      </h1>
      <p class='text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed'>
        Todo lo que necesitás saber para ser parte activa de ShareIT: nuestros
        canales, las reglas de convivencia y los próximos eventos.
      </p>
    </div>
  </section>

  <main class='bg-gray-900'>
    <section id='canales'>
      <div class='container mx-auto px-6 max-w-6xl'>
        <div class='text-center mb-16'>
          <h2 class='text-4xl font-bold text-white'>
            <span class='section-heading__accent_doble'>Grupos</span> de <span
              class='text-[#ff6900]'>WhatsApp</span
            >
          </h2>
          <p class='text-gray-400 mt-4 text-lg'>
            Únete a los espacios donde sucede la magia día a día.
          </p>
        </div>

        <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8'>
          {
            whatsappGroups
              .sort((a, b) => a.order - b.order)
              .map((group, index) => (
                <DiscordGroupCard
                  index={index}
                  title={group.title}
                  description={group.description}
                  icon={group.icon}
                  image={group.image}
                  referents={getGroupReferentsByIds(group.referrals)}
                />
              ))
          }
        </div>

        
        <div class='mt-12 relative overflow-hidden rounded-2xl border border-[#ff6900]/40 bg-transparent px-8 py-7 flex flex-col sm:flex-row items-center gap-6 shadow-[0_0_40px_rgba(255,105,0,0.08)]'>
          <!-- Glow decorativo -->
          <div class='absolute -top-10 -left-10 w-48 h-48 bg-[#ff6900]/8 rounded-full blur-3xl pointer-events-none'></div>
          <div class='absolute -bottom-10 -right-10 w-48 h-48 bg-[#ff6900]/8 rounded-full blur-3xl pointer-events-none'></div>

          
          <div class='relative shrink-0 flex items-center justify-center w-16 h-16 rounded-2xl bg-[#ff6900]/10 border border-[#ff6900]/30 shadow-[0_0_20px_rgba(255,105,0,0.2)]'>
            <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' class='w-9 h-9 fill-[#ff6900]' aria-hidden='true'>
              <path d='M16 0C7.163 0 0 7.163 0 16c0 2.833.737 5.494 2.027 7.808L0 32l8.418-2.007A15.93 15.93 0 0 0 16 32c8.837 0 16-7.163 16-16S24.837 0 16 0zm0 29.333a13.27 13.27 0 0 1-6.77-1.849l-.485-.29-5 1.193 1.215-4.862-.317-.5A13.253 13.253 0 0 1 2.667 16C2.667 8.636 8.636 2.667 16 2.667S29.333 8.636 29.333 16 23.364 29.333 16 29.333zm7.293-9.907c-.4-.2-2.365-1.167-2.731-1.3-.367-.133-.634-.2-.9.2s-1.033 1.3-1.267 1.567c-.233.267-.467.3-.867.1-.4-.2-1.688-.622-3.216-1.984-1.188-1.06-1.99-2.37-2.223-2.77-.233-.4-.025-.616.175-.815.18-.178.4-.467.6-.7.2-.233.267-.4.4-.667.133-.267.067-.5-.033-.7-.1-.2-.9-2.167-1.233-2.967-.325-.78-.655-.674-.9-.686l-.767-.013c-.267 0-.7.1-1.067.5s-1.4 1.367-1.4 3.333 1.433 3.867 1.633 4.133c.2.267 2.82 4.307 6.833 6.033.954.412 1.699.658 2.28.842.958.305 1.83.262 2.52.159.769-.114 2.365-.967 2.7-1.9.333-.933.333-1.733.233-1.9-.1-.167-.367-.267-.767-.467z'/>
            </svg>
          </div>

          <!-- Texto -->
          <div class='relative flex-1 text-center sm:text-left'>
            <p class='text-[#ff6900] font-bold text-sm uppercase tracking-widest mb-1'>ShareIT – Oportunidades Laborales</p>
            <p class='text-white text-base md:text-lg leading-relaxed'>
              Si estás buscando trabajo disponemos de un canal de WhatsApp donde compartimos ofertas todas las semanas. Sumate desde acá
            </p>
          </div>

          <!-- CTA -->
          <a
            href='https://whatsapp.com/channel/0029VbCADxFBlHpjWmAKha01'
            target='_blank'
            rel='noopener noreferrer'
            class='relative shrink-0 inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[#ff6900] text-white font-bold text-sm transition-all duration-300 hover:scale-105 hover:shadow-[0_0_25px_rgba(255,105,0,0.45)] whitespace-nowrap'
          >
            <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' class='w-4 h-4 fill-white' aria-hidden='true'>
              <path d='M16 0C7.163 0 0 7.163 0 16c0 2.833.737 5.494 2.027 7.808L0 32l8.418-2.007A15.93 15.93 0 0 0 16 32c8.837 0 16-7.163 16-16S24.837 0 16 0zm0 29.333a13.27 13.27 0 0 1-6.77-1.849l-.485-.29-5 1.193 1.215-4.862-.317-.5A13.253 13.253 0 0 1 2.667 16C2.667 8.636 8.636 2.667 16 2.667S29.333 8.636 29.333 16 23.364 29.333 16 29.333zm7.293-9.907c-.4-.2-2.365-1.167-2.731-1.3-.367-.133-.634-.2-.9.2s-1.033 1.3-1.267 1.567c-.233.267-.467.3-.867.1-.4-.2-1.688-.622-3.216-1.984-1.188-1.06-1.99-2.37-2.223-2.77-.233-.4-.025-.616.175-.815.18-.178.4-.467.6-.7.2-.233.267-.4.4-.667.133-.267.067-.5-.033-.7-.1-.2-.9-2.167-1.233-2.967-.325-.78-.655-.674-.9-.686l-.767-.013c-.267 0-.7.1-1.067.5s-1.4 1.367-1.4 3.333 1.433 3.867 1.633 4.133c.2.267 2.82 4.307 6.833 6.033.954.412 1.699.658 2.28.842.958.305 1.83.262 2.52.159.769-.114 2.365-.967 2.7-1.9.333-.933.333-1.733.233-1.9-.1-.167-.367-.267-.767-.467z'/>
            </svg>
            Unirme al canal
          </a>
        </div>
      </div>
    </section>

    <SectionDivider />

    <!-- REGLAS -->
    <section class='py-20 md:py-32 bg-gray-900/30' id='reglas'>
      <div class='container mx-auto px-6 max-w-5xl'>
        <div class='text-center mb-16'>
          <h2 class='text-4xl font-bold text-white mb-4'>
            <span class='section-heading__accent_doble'>Reglas</span> de <span
              class='text-[#00e5ff]'>Convivencia</span
            >
          </h2>
          <p class='text-xl text-gray-400 max-w-2xl mx-auto'>
            Para mantener un espacio sano, respetuoso y productivo para todos.
          </p>
        </div>

        <div
          class='flex overflow-x-auto snap-x snap-mandatory sm:grid sm:grid-cols-2 gap-6 sm:gap-8 pb-8 -mx-6 px-6 sm:mx-0 sm:px-0 sm:pb-0 custom-scrollbar'
        >
          {
            COMMUNITY_RULES.map((rule) => (
              <div class='snap-center shrink-0 w-[85vw] sm:w-auto group relative p-8 bg-[#0a0f1d]/60 border border-white/5 rounded-3xl transition-all duration-500 hover:shadow-[0_0_40px_rgba(255,105,0,0.08)] hover:-translate-y-1 backdrop-blur-md overflow-hidden'>
                <div class='absolute -right-10 -bottom-10 w-32 h-32 bg-[#ff6900]/5 rounded-full blur-2xl group-hover:bg-[#ff6900]/10 transition-colors' />

                <div class='relative z-10 flex items-start gap-6'>
                  <div class='text-5xl font-black text-white/5 group-hover:text-[#ff6900]/20 shrink-0 leading-none select-none transition-colors duration-500'>
                    {rule.number}
                  </div>
                  <div>
                    <h3 class='text-xl font-bold text-white mb-2 group-hover:text-[#ff6900] transition-colors'>
                      {rule.title}
                    </h3>
                    <p class='text-gray-400 text-lg leading-relaxed'>
                      {rule.description}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <div
          class='flex justify-end items-center sm:hidden animate-pulse mb-8 pr-2 gap-2 text-[#00e5ff] text-sm font-medium opacity-80'
        >
          Desliza para ver más <i class='fa-solid fa-arrow-right-long'></i>
        </div>

        <div class='mt-8 sm:mt-16 flex justify-center'>
          <a
            href='/rules'
            class='group relative px-10 py-4 bg-[#ff6900] text-white font-bold rounded-2xl transition-all duration-300 hover:scale-105 hover:shadow-[0_0_30px_rgba(255,105,0,0.4)] overflow-hidden'
          >
            <span class='relative z-10 flex items-center gap-2'>
              Ver reglas completas <i class='fa-solid fa-arrow-right text-sm'
              ></i>
            </span>
          </a>
        </div>
      </div>
    </section>

    <SectionDivider />

    <section class='py-20 md:py-32' id='eventos'>
      <div class='container mx-auto px-6 max-w-5xl'>
        <div class='text-center mb-16'>
          <h2 class='text-4xl font-bold text-white mb-4'>
            <span class='section-heading__accent_doble'>Eventos</span> y <span
              class='text-[#00e5ff]'>Workshops</span
            >
          </h2>
          <p class='text-xl text-gray-400 max-w-2xl mx-auto'>
            Explora nuestros encuentros comunitarios y espacios de aprendizaje.
          </p>
        </div>

        <!-- Tabs Header -->
        <div class='flex justify-center mb-12'>
          <div
            class='inline-flex p-1.5 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-md'
          >
            <button
              id='btn-tab-community'
              class='tab-btn px-8 py-3 rounded-xl text-md font-bold transition-all duration-300 bg-[#00e5ff] text-[#0a0f1d] shadow-xl shadow-[#00e5ff]/20'
              data-tab='community'
            >
              Comunidad
            </button>
            <button
              id='btn-tab-learning'
              class='tab-btn px-8 py-3 rounded-xl text-md font-bold transition-all duration-300 text-gray-400 hover:text-white'
              data-tab='learning'
            >
              Workshops
            </button>
          </div>
        </div>

        <div class='relative min-h-[400px]'>
          <!-- Tab Content: COMMUNITY -->
          <div
            id='tab-community'
            class='space-y-16 block transition-all duration-500 animate-fadeIn'
          >
            <div
              class='bg-[#1d2c49]/10 border border-[#314aa9]/10 rounded-3xl p-8 md:p-12'
            >
              <h3
                class='text-2xl font-bold text-white mb-8 flex items-center gap-4'
              >
                <div
                  class='w-3 h-3 rounded-full bg-[#00e5ff] shadow-[0_0_15px_#00e5ff]'
                >
                </div>
                Próximos Encuentros
              </h3>

              {
                upcomingCommunity.length === 0 ? (
                  <p class='text-gray-500 italic text-center py-10 bg-[#0a0f1d]/40 rounded-2xl border border-white/5'>
                    No hay encuentros programados por ahora. ¡Vuelve pronto!
                  </p>
                ) : (
                  <div class='space-y-6'>
                    {upcomingCommunity.map((event) => (
                      <div class='transform transition-all hover:scale-[1.01]'>
                        <UpcomingEventCard event={event} />
                      </div>
                    ))}
                  </div>
                )
              }
            </div>

            {
              pastCommunity.length > 0 && (
                <div>
                  <h3 class='text-2xl font-bold text-white mb-8 px-4'>
                    Recientes
                  </h3>
                  <div class='bg-gray-900/40 rounded-3xl p-8 border border-white/5'>
                    <Events events={pastCommunity} />
                  </div>
                </div>
              )
            }
          </div>

          <!-- Tab Content: LEARNING -->
          <div
            id='tab-learning'
            class='space-y-16 hidden transition-all duration-500 animate-fadeIn'
          >
            <div
              class='bg-[#ff6900]/5 border border-[#ff6900]/10 rounded-3xl p-8 md:p-12'
            >
              <h3
                class='text-2xl font-bold text-white mb-8 flex items-center gap-4'
              >
                <div
                  class='w-3 h-3 rounded-full bg-[#ff6900] shadow-[0_0_15px_#ff6900]'
                >
                </div>
                Próximas Sesiones
              </h3>

              {
                upcomingLearning.length === 0 ? (
                  <p class='text-gray-500 italic text-center py-10 bg-[#0a0f1d]/40 rounded-2xl border border-white/5'>
                    No hay workshops próximos. ¡Mira nuestro historial!
                  </p>
                ) : (
                  <div class='space-y-6'>
                    {upcomingLearning.map((event) => (
                      <div class='transform transition-all hover:scale-[1.01]'>
                        <UpcomingEventCard event={event} showProximo={true} />
                      </div>
                    ))}
                  </div>
                )
              }
            </div>

            <div>
              <h3 class='text-2xl font-bold text-white mb-8 px-4'>
                Workshops Anteriores
              </h3>
              <div class='bg-gray-900/40 rounded-3xl p-8 border border-white/5'>
                <Events events={pastLearning} />
              </div>
            </div>
          </div>
        </div>

        <div
          class='mt-24 p-8 bg-gradient-to-r from-[#1d2c49]/20 to-transparent border-l-4 border-[#00e5ff] rounded-r-2xl'
        >
          <p class='text-white text-lg font-medium'>
            Los eventos se coordinan a través de nuestro servidor de Discord.
            <a
              href='https://discord.gg/shareit'
              target='_blank'
              rel='noopener noreferrer'
              class='text-[#ff6900] hover:text-[#ff8533] transition-colors font-bold ml-1'
            >
              ¡Únete para no perderte ninguno!
            </a>
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  function setupTabs() {
    const btns = document.querySelectorAll('.tab-btn')
    const tabs = {
      community: document.getElementById('tab-community'),
      learning: document.getElementById('tab-learning'),
    }

    if (!btns.length) return

    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-tab')

        // Update buttons
        btns.forEach((b) => {
          b.classList.remove(
            'bg-[#00e5ff]',
            'text-[#0a0f1d]',
            'shadow-xl',
            'shadow-[#00e5ff]/20',
          )
          b.classList.add('text-gray-400', 'hover:text-white')
        })
        btn.classList.add(
          'bg-[#00e5ff]',
          'text-[#0a0f1d]',
          'shadow-xl',
          'shadow-[#00e5ff]/20',
        )
        btn.classList.remove('text-gray-400', 'hover:text-white')

        // Update tabs
        Object.keys(tabs).forEach((key) => {
          if (key === target) {
            tabs[key].classList.remove('hidden')
            tabs[key].classList.add('block')
          } else {
            tabs[key].classList.add('hidden')
            tabs[key].classList.remove('block')
          }
        })
      })
    })
  }

  function handleExpiredEvents() {
    const now = new Date()
    const upcomingCards = document.querySelectorAll('.upcoming-event-card')
    const containers = new Set()

    upcomingCards.forEach((card) => {
      const endStr = card.getAttribute('data-event-end')
      if (!endStr || endStr.trim() === '') return

      const endDate = new Date(endStr)
      if (now > endDate) {
        card.style.display = 'none'
        containers.add(card.parentElement)
      }
    })

    containers.forEach((container) => {
      const visibleCards = container.querySelectorAll(
        '.upcoming-event-card:not([style*="display: none"])',
      )
      if (visibleCards.length === 0) {
        const emptyState = container.parentElement.querySelector('.empty-state')
        if (emptyState) {
          emptyState.classList.remove('hidden')
          container.style.display = 'none'
        }
      }
    })
  }

  function updateLocalTimes() {
    const timeElements = document.querySelectorAll('[data-event-date]')
    const argZone = 'America/Argentina/Buenos_Aires'

    timeElements.forEach((el) => {
      const dateStr = el.getAttribute('data-event-date')
      if (!dateStr) return
      const date = new Date(dateStr)

      const argTime = date.toLocaleString('es-ES', {
        hour: '2-digit',
        minute: '2-digit',
        timeZone: argZone,
      })

      const localTime = date.toLocaleString('es-ES', {
        hour: '2-digit',
        minute: '2-digit',
      })

      if (argTime !== localTime) {
        el.innerHTML += ` / <span class="text-white/40 normal-case font-normal">tu hora local: ${localTime}hs</span>`
      }
    })
  }

  document.addEventListener('astro:page-load', () => {
    setupTabs()
    handleExpiredEvents()
    updateLocalTimes()
  })
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fadeIn {
    animation: fadeIn 0.5s ease-out forwards;
  }
</style>
