---
import Layout from 'src/modules/global/layouts/Layout.astro'
import Events from 'src/modules/resources/components/Events.astro'
import UpcomingEventCard from 'src/modules/resources/components/UpcomingEventCard.astro'
import DiscordGroupCard from 'src/modules/community/components/DiscordGroupCard.astro'
import { whatsappGroups } from 'src/modules/global/constants/channels.const'
import { EVENTS } from 'src/modules/global/constants/events.const'
import { getGroupedEvents } from 'src/modules/global/utils/events.utils'

const { upcomingCommunity, pastCommunity, upcomingLearning, pastLearning } =
  getGroupedEvents(EVENTS)
---

<Layout title='ShareIT - Comunidad'>
  <section class='text-center py-10 mb-6'>
    <h1 class='text-4xl font-bold text-center mb-8 text-white'>
      Bienvenido a la comunidad
    </h1>
    <p class='text-gray-400 max-w-xl mx-auto text-lg'>
      Todo lo que necesitás saber para ser parte activa de Share IT: nuestros
      canales, las reglas de convivencia y los próximos eventos.
    </p>
  </section>
  <section class='pb-10 mb-16' id='canales'>
    <div class='flex items-center gap-3 mt-6 mb-8'>
      <span class='text-2xl'>💬</span>
      <h2 class='text-3xl font-bold text-white'>
        <span class='section-heading__accent'>Grupos</span> de WhatsApp
      </h2>
    </div>

    <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6'>
      {
        whatsappGroups.map((group, index) => (
          <DiscordGroupCard
            index={index}
            title={group.title}
            description={group.description}
            icon={group.icon}
            image={group.image}
          />
        ))
      }
    </div>
  </section>

  <div class='border-t border-gray-800 mb-16'></div>

  <!-- REGLAS -->
  <section class='mb-16' id='reglas'>
    <div class='flex items-center gap-3 mb-2'>
      <span class='text-2xl'>📋</span>
      <h2 class='text-3xl font-bold text-white'>
        <span class='section-heading__accent'>Reglas</span> de convivencia
      </h2>
    </div>
    <p class='text-gray-400 mb-8 ml-1'>
      Para mantener un espacio sano, respetuoso y productivo para todos.
    </p>

    <div class='grid grid-cols-1 sm:grid-cols-2 gap-6'>
      <div
        class='group p-6 flex items-start gap-4 bg-gray-800/40 border border-gray-700/60 rounded-2xl transition-all duration-200 hover:border-gray-600 hover:scale-[1.02]'
      >
        <div
          class='text-2xl font-extrabold text-gray-700 group-hover:text-white shrink-0 leading-none pt-0.5 select-none transition-colors duration-200'
        >
          01
        </div>
        <div>
          <h3 class='font-semibold text-white mb-1'>Respeto ante todo</h3>
          <p class='text-gray-400 text-sm'>
            Tratá a los demás como te gustaría ser tratado/a. No se toleran
            insultos, discriminación ni actitudes hostiles.
          </p>
        </div>
      </div>
      <div
        class='group p-6 flex items-start gap-4 bg-gray-800/40 border border-gray-700/60 rounded-2xl transition-all duration-200 hover:border-gray-600 hover:scale-[1.02]'
      >
        <div
          class='text-2xl font-extrabold text-gray-700 group-hover:text-white shrink-0 leading-none pt-0.5 select-none transition-colors duration-200'
        >
          02
        </div>
        <div>
          <h3 class='font-semibold text-white mb-1'>Canales correctos</h3>
          <p class='text-gray-400 text-sm'>
            Publicá en el canal que corresponde al tema. Esto ayuda a mantener
            las conversaciones ordenadas y fáciles de encontrar.
          </p>
        </div>
      </div>
      <div
        class='group p-6 flex items-start gap-4 bg-gray-800/40 border border-gray-700/60 rounded-2xl transition-all duration-200 hover:border-gray-600 hover:scale-[1.02]'
      >
        <div
          class='text-2xl font-extrabold text-gray-700 group-hover:text-white shrink-0 leading-none pt-0.5 select-none transition-colors duration-200'
        >
          03
        </div>
        <div>
          <h3 class='font-semibold text-white mb-1'>Sin spam ni publicidad</h3>
          <p class='text-gray-400 text-sm'>
            Está prohibido el spam, la publicidad no solicitada y el envío
            masivo de mensajes privados a miembros sin su consentimiento.
          </p>
        </div>
      </div>
      <div
        class='group p-6 flex items-start gap-4 bg-gray-800/40 border border-gray-700/60 rounded-2xl transition-all duration-200 hover:border-gray-600 hover:scale-[1.02]'
      >
        <div
          class='text-2xl font-extrabold text-gray-700 group-hover:text-white shrink-0 leading-none pt-0.5 select-none transition-colors duration-200'
        >
          04
        </div>
        <div>
          <h3 class='font-semibold text-white mb-1'>Contenido apropiado</h3>
          <p class='text-gray-400 text-sm'>
            No compartas contenido ofensivo, violento, pornográfico o ilegal.
            Mantén el ambiente seguro y adecuado para todos los miembros.
          </p>
        </div>
      </div>
      <div
        class='group p-6 flex items-start gap-4 bg-gray-800/40 border border-gray-700/60 rounded-2xl transition-all duration-200 hover:border-gray-600 hover:scale-[1.02]'
      >
        <div
          class='text-2xl font-extrabold text-gray-700 group-hover:text-white shrink-0 leading-none pt-0.5 select-none transition-colors duration-200'
        >
          05
        </div>
        <div>
          <h3 class='font-semibold text-white mb-1'>Moderación final</h3>
          <p class='text-gray-400 text-sm'>
            Las decisiones del equipo de moderación son definitivas. Si tenés
            dudas, podés consultar en privado con los moderadores.
          </p>
        </div>
      </div>
      <div
        class='group p-6 flex items-start gap-4 bg-gray-800/40 border border-gray-700/60 rounded-2xl transition-all duration-200 hover:border-gray-600 hover:scale-[1.02]'
      >
        <div
          class='text-2xl font-extrabold text-gray-700 group-hover:text-white shrink-0 leading-none pt-0.5 select-none transition-colors duration-200'
        >
          06
        </div>
        <div>
          <h3 class='font-semibold text-white mb-1'>Divertirse</h3>
          <p class='text-gray-400 text-sm'>
            ¡Pasala bien! Share IT existe para aprender juntos, hacer networking
            y crecer. Sé positivo/a y suma a la comunidad.
          </p>
        </div>
      </div>
    </div>

    <div class='mt-8 flex justify-center'>
      <a
        href='/rules'
        class='inline-flex items-center p-6 gap-2 border border-gray-600 hover:border-primary text-gray-300 hover:text-primary font-medium px-7 py-3 rounded-full transition-all duration-200 hover:-translate-y-0.5'
      >
        Ver reglas completas →
      </a>
    </div>
  </section>

  <div class='border-t border-gray-800 mb-16'></div>

  <section class='mb-12' id='eventos'>
    <div class='flex items-center gap-3 mb-2'>
      <span class='text-2xl'>🗓️</span>
      <h2 class='text-3xl font-bold text-white'>
        <span class='section-heading__accent'>Eventos</span> y Workshops
      </h2>
    </div>
    <p class='text-gray-400 mb-8 ml-1'>
      Explora nuestros encuentros comunitarios y espacios de aprendizaje.
    </p>

    <!-- Tabs Header -->
    <div
      class='flex flex-wrap justify-center gap-2 mb-10 p-1 bg-gray-900/50 border border-gray-800 rounded-2xl w-fit mx-auto'
    >
      <button
        id='btn-tab-community'
        class='tab-btn px-6 py-2.5 rounded-xl text-sm font-bold transition-all duration-300 bg-primary text-white shadow-lg shadow-primary/20'
        data-tab='community'
      >
        Comunidad
      </button>
      <button
        id='btn-tab-learning'
        class='tab-btn px-6 py-2.5 rounded-xl text-sm font-bold transition-all duration-300 text-gray-400 hover:text-white hover:bg-gray-800'
        data-tab='learning'
      >
        Workshops
      </button>
    </div>

    <!-- Tab Content: COMMUNITY -->
    <div
      id='tab-community'
      class='space-y-12 block transition-opacity duration-300'
    >
      <div>
        <h3 class='text-xl font-bold text-white mb-6 flex items-center gap-2'>
          <span class='w-2 h-2 rounded-full bg-primary'></span>
          Próximos Encuentros
        </h3>
        <p class='empty-state hidden text-gray-500 italic p-6 border border-gray-800/50 rounded-2xl bg-gray-900/20'>
          No hay encuentros programados por ahora. ¡Vuelve pronto!
        </p>
        {
          upcomingCommunity.length === 0 ? (
            <p class='text-gray-500 italic p-6 border border-gray-800/50 rounded-2xl bg-gray-900/20'>
              No hay encuentros programados por ahora. ¡Vuelve pronto!
            </p>
          ) : (
            <div class='space-y-4'>
              {upcomingCommunity.map((event) => (
                <UpcomingEventCard event={event} />
              ))}
            </div>
          )
        }
      </div>

      {
        pastCommunity.length > 0 && (
          <div>
            <h3 class='text-xl font-bold text-white mb-6'>Recientes</h3>
            <Events events={pastCommunity} />
          </div>
        )
      }
    </div>

    <!-- Tab Content: LEARNING -->
    <div
      id='tab-learning'
      class='space-y-12 hidden transition-opacity duration-300'
    >
      <div>
        <h3 class='text-xl font-bold text-white mb-6 flex items-center gap-2'>
          <span class='w-2 h-2 rounded-full bg-secondary'></span>
          Próximas Sesiones
        </h3>
        <p class='empty-state hidden text-gray-500 italic p-6 border border-gray-800/50 rounded-2xl bg-gray-900/20'>
          No hay workshops próximos. ¡Mira nuestro historial!
        </p>
        {
          upcomingLearning.length === 0 ? (
            <p class='text-gray-500 italic p-6 border border-gray-800/50 rounded-2xl bg-gray-900/20'>
              No hay workshops próximos. ¡Mira nuestro historial!
            </p>
          ) : (
            <div class='space-y-4'>
              {upcomingLearning.map((event) => (
                <UpcomingEventCard event={event} showProximo={true} />
              ))}
            </div>
          )
        }
      </div>

      <div>
        <h3 class='text-xl font-bold text-white mb-6'>Workshops Anteriores</h3>
        <Events events={pastLearning} />
      </div>
    </div>

    <p class='text-center text-gray-500 text-sm mt-16'>
      Los eventos se coordinan a través de nuestro servidor de Discord.
      <a
        href='https://discord.gg/shareit'
        target='_blank'
        rel='noopener noreferrer'
        class='text-primary hover:text-secondary transition-colors'
      >
        ¡Únete para no perderte ninguno!
      </a>
    </p>
  </section>
</Layout>

<script is:inline>
  function setupTabs() {
    const btns = document.querySelectorAll('.tab-btn')
    const tabs = {
      community: document.getElementById('tab-community'),
      learning: document.getElementById('tab-learning'),
    }

    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-tab')

        // Update buttons
        btns.forEach((b) => {
          b.classList.remove(
            'bg-primary',
            'text-white',
            'shadow-lg',
            'shadow-primary/20',
          )
          b.classList.add(
            'text-gray-400',
            'hover:text-white',
            'hover:bg-gray-800',
          )
        })
        btn.classList.add(
          'bg-primary',
          'text-white',
          'shadow-lg',
          'shadow-primary/20',
        )
        btn.classList.remove(
          'text-gray-400',
          'hover:text-white',
          'hover:bg-gray-800',
        )

        // Update tabs
        Object.keys(tabs).forEach((key) => {
          if (key === target) {
            tabs[key].classList.remove('hidden')
            tabs[key].classList.add('block')
          } else {
            tabs[key].classList.add('hidden')
            tabs[key].classList.remove('block')
          }
        })
      })
    })
  }

  function handleExpiredEvents() {
    const now = new Date()
    const upcomingCards = document.querySelectorAll('.upcoming-event-card')
    const containers = new Set()

    upcomingCards.forEach((card) => {
      const endStr = card.getAttribute('data-event-end')
      if (!endStr || endStr.trim() === '') return

      const endDate = new Date(endStr)
      if (now > endDate) {
        card.style.display = 'none'
        containers.add(card.parentElement)
      }
    })

    // Check if containers are now empty
    containers.forEach((container) => {
      const visibleCards = container.querySelectorAll(
        '.upcoming-event-card:not([style*="display: none"])',
      )
      if (visibleCards.length === 0) {
        // Show empty state if it exists, or create one
        const emptyState = container.parentElement.querySelector('.empty-state')
        if (emptyState) {
          emptyState.classList.remove('hidden')
          container.style.display = 'none'
        }
      }
    })
  }

  function updateLocalTimes() {
    const timeElements = document.querySelectorAll('[data-event-date]')
    const argZone = 'America/Argentina/Buenos_Aires'

    timeElements.forEach((el) => {
      const dateStr = el.getAttribute('data-event-date')
      if (!dateStr) return
      const date = new Date(dateStr)

      // Get Argentina Time for comparison
      const argTime = date.toLocaleString('es-ES', {
        hour: '2-digit',
        minute: '2-digit',
        timeZone: argZone,
      })

      // Get Local Time
      const localTime = date.toLocaleString('es-ES', {
        hour: '2-digit',
        minute: '2-digit',
      })

      // If different, append local time
      if (argTime !== localTime) {
        el.innerHTML += ` / <span class="text-white/40 normal-case font-normal">tu hora local: ${localTime}hs</span>`
      }
    })
  }

  // Run on load
  setupTabs()
  handleExpiredEvents()
  updateLocalTimes()
</script>
