---
import { RulesTimelines } from 'src/modules/rules/components/RulesTimelines'
import Layout from 'src/modules/global/layouts/Layout.astro'
import SectionDivider from 'src/modules/home/components/SectionDivider.astro'
import '@fontsource/josefin-sans'
---

<Layout title='Reglas | ShareIT' fullWidth={true}>
  <section class='relative bg-gray-900 pt-20 overflow-hidden'>
    {/* Background Glow */}
    <div
      class='absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-full bg-[#ff6900]/5 blur-[120px] -z-10'
    >
    </div>

    <div class='max-w-4xl mx-auto relative z-10 text-center font-josefin-sans'>
      <h1
        class='text-5xl md:text-6xl font-extrabold mb-8 text-white tracking-tight'
      >
        Reglas de la <span class='text-[#00e5ff]'>Comunidad</span>
      </h1>
      <p class='text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed'>
        Estas son las reglas de la comunidad que facilitan una sana y productiva
        convivencia entre los miembros de la misma. Por favor lee atentamente
        cada una de ellas ya que su incumplimiento puede derivar en sanciones o
        incluso la expulsion del grupo en cuestion o la misma comunidad. 🚀
      </p>
    </div>
  </section>

  <main class='font-josefin-sans bg-gray-900 py-20'>
    <div class='max-w-4xl mx-auto px-6'>
      <RulesTimelines client:load />
    </div>
  </main>
</Layout>

<style>
  .section-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 105, 0, 0.3),
      transparent
    );
    margin: 4rem 0;
  }
</style>
