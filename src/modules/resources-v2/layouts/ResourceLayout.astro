---
import { ClientRouter } from 'astro:transitions'
import Sidebar from '../components/ResourceLayout/Sidebar'
import MobileMenu from '../components/ResourceLayout/MobileMenu'
import '../../global/styles/globals.css'

interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang='es' class='dark'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/share-it-icon.png' />
    <meta name='generator' content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class='bg-gray-900 min-h-screen flex flex-col'>
    <!-- Mobile Nav Header -->
    <div
      class='md:hidden sticky top-0 z-50 bg-gray-900 border-b border-slate-800/50 px-6 py-4 flex items-center justify-between'
    >
      <MobileMenu client:load />
    </div>

    <div
      id='main-container'
      class='flex flex-col md:flex-row min-h-screen'
      data-sidebar-collapsed='false'
    >
      <aside
        id='sidebar-aside'
        class='hidden md:block fixed inset-y-0 left-0 z-40 bg-[#1d2939] border-r border-slate-800/50 transition-all duration-300'
      >
        <div class='h-full overflow-y-auto custom-scrollbar'>
          <Sidebar client:load />
        </div>
      </aside>

      <!-- Main Content -->
      <main
        id='main-content'
        class='flex-1 min-h-screen transition-all duration-300'
      >
        <div class='max-w-7xl mx-auto px-6 lg:px-12 py-10'>
          <slot />
        </div>
      </main>
    </div>

    <script>
      import { isSidebarCollapsed } from '../store/resourceStore'

      const container = document.getElementById('main-container')

      if (container) {
        isSidebarCollapsed.subscribe((collapsed) => {
          container.setAttribute('data-sidebar-collapsed', collapsed.toString())
        })
      }
    </script>

    <style is:global>
      #sidebar-aside {
        width: 18rem; /* 72 */
      }

      @media (min-width: 1024px) {
        #sidebar-aside {
          width: 20rem; /* 80 */
        }
      }

      #main-content {
        margin-left: 18rem;
      }

      @media (min-width: 1024px) {
        #main-content {
          margin-left: 20rem;
        }
      }

      [data-sidebar-collapsed='true'] #sidebar-aside {
        width: 5rem; /* 20 */
      }

      [data-sidebar-collapsed='true'] #main-content {
        margin-left: 5rem;
      }

      @media (max-width: 767px) {
        #sidebar-aside {
          width: 0;
        }
        #main-content {
          margin-left: 0;
        }
      }

      .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
      }
      .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #1e293b;
        border-radius: 10px;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #334155;
      }

      .resource-grid-item {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }
    </style>
  </body>
</html>
