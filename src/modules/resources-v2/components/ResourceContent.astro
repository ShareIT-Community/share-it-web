---
import SearchBar from './ResourceContent/SearchBar'
import ResourceGrid from './ResourceContent/ResourceGrid'
import ResourceHeader from './ResourceLayout/ResourceHeader'
import StatusFilters from './ResourceContent/StatusFilters'
---

<div class='flex flex-col gap-12'>
  <div class='flex flex-col gap-8'>
    <ResourceHeader />

    <div class='flex flex-col gap-6'>
      <div class='flex flex-col md:flex-row md:items-center gap-4'>
        <SearchBar client:load />
      </div>
      <StatusFilters client:load />
    </div>
  </div>

  <ResourceGrid client:load />
</div>
