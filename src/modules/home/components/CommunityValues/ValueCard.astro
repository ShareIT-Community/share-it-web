---
interface Props {
  title: string;
  description: string;
  icon: string;
  color: string;
  bullets?: string[];
}

const { title, description, icon, color, bullets } = Astro.props;
---

<div class={`group p-6 rounded-2xl bg-[#1d2c49]/40 border border-[#314aa9]/30 hover:border-${color} transition-all duration-300 hover:shadow-[0_0_30px_rgba(49,74,169,0.2)] hover:-translate-y-1 flex flex-col items-center text-center backdrop-blur-sm h-full`}>
  <div class={`w-14 h-14 rounded-full bg-gradient-to-br from-[#1d2c49] to-[#314aa9] flex items-center justify-center mb-6 border border-[#314aa9]/50 group-hover:scale-110 transition-transform duration-300 text-white`}>
    <Fragment set:html={icon} />
  </div>
  <h3 class={`text-xl font-bold mb-3 text-white group-hover:text-${color} transition-colors duration-300`}>
    {title}
  </h3>
  <p class="text-gray-400 text-sm leading-relaxed mb-4">
    {description}
  </p>
  {bullets && bullets.length > 0 && (
    <ul class="text-left w-full space-y-3 mt-auto">
      {bullets.map((bullet) => (
        <li class="flex gap-3 items-start text-xs text-gray-400">
          <div class={`mt-1.5 min-w-[6px] h-[6px] rounded-full bg-${color} group-hover:shadow-[0_0_8px_rgba(255,255,255,0.4)] transition-all`}></div>
          <span class="leading-relaxed">{bullet}</span>
        </li>
      ))}
    </ul>
  )}
</div>

<style>
  div {
    will-change: transform, opacity;
  }
</style>
