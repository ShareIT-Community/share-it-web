<div class="flex justify-center w-full py-12 overflow-hidden">
  <div class="relative w-full max-w-md h-[1px]">
    {/* Base Gradient Line */}
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-[#ff6900] to-transparent opacity-30"></div>
    
    {/* Inner Brighter Line */}
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-[#ff6900] to-transparent scale-x-50"></div>
    
    {/* Glow effect */}
    <div class="absolute inset-0 bg-[#ff6900] blur-[8px] opacity-20 scale-x-75"></div>
    <div class="absolute inset-0 bg-[#ff6900] blur-[20px] opacity-10 scale-x-125"></div>
  </div>
</div>
