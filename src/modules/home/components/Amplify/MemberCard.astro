---
interface Props {
  name: string;
  role: string;
  photo: string;
  description?: string;
  linkedin?: string;
  github?: string;
  twitter?: string;
  instagram?: string;
  website?: string;
}

const { name, role, photo, description, linkedin, github, twitter, instagram, website } = Astro.props;

const socials = [
  { key: 'linkedin', url: linkedin, icon: 'fa-brands fa-linkedin', label: 'LinkedIn', color: '#0A66C2' },
  { key: 'github',   url: github,   icon: 'fa-brands fa-github',   label: 'GitHub',   color: '#e0e0e0' },
  { key: 'twitter',  url: twitter,  icon: 'fa-brands fa-x-twitter', label: 'Twitter/X', color: '#1DA1F2' },
  { key: 'instagram',url: instagram,icon: 'fa-brands fa-instagram', label: 'Instagram', color: '#E1306C' },
  { key: 'website',  url: website,  icon: 'fa-solid fa-globe',      label: 'Website',  color: '#4b6ef8' },
].filter(s => s.url);
---

<div class="member-card flex flex-col p-6 rounded-2xl bg-[#1d2c49]/40 border border-[#314aa9]/30 transition-all duration-300 backdrop-blur-sm h-full w-full">
  <!-- Header: avatar + name/role side by side -->
  <div class="flex items-center gap-4 mb-4">
    <div class="w-14 h-14 rounded-xl overflow-hidden border-2 border-[#314aa9]/50 avatar-border transition-colors duration-300 flex-shrink-0">
      <img
        src={photo}
        alt={name}
        class="w-full h-full object-cover avatar-img transition-transform duration-500"
      />
    </div>
    <div>
      <h3 class="text-lg font-bold text-white name-text transition-colors duration-300 leading-tight">
        {name}
      </h3>
      <p class="text-gray-400 text-sm font-medium">
        {role}
      </p>
    </div>
  </div>

  <!-- Description -->
  {description && (
    <p class="text-gray-400 text-sm leading-relaxed flex-1 mb-28">
      {description}
    </p>
  )}

  <!-- Social icons -->
  {socials.length > 0 && (
    <div class="flex items-center gap-3 mt-auto pt-3 border-t border-[#314aa9]/20">
      {socials.map(s => (
        <a
          href={s.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={s.label}
          class="social-icon text-gray-400 transition-colors duration-200 text-lg hover:scale-110 transition-transform"
          style={`--hover-color: ${s.color}`}
        >
          <i class={s.icon}></i>
        </a>
      ))}
    </div>
  )}
</div>

<style>
  .member-card {
    will-change: transform, border-color, box-shadow;
  }

  .social-icon:hover {
    color: var(--hover-color);
  }


</style>
