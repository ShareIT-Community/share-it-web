---
interface Props {
  name: string;
  role: string;
  photo: string;
  profileUrl: string;
}

const { name, role, photo, profileUrl } = Astro.props;
---

<div 
  class="member-card flex flex-col items-center p-6 rounded-2xl bg-[#1d2c49]/40 border border-[#314aa9]/30 transition-all duration-300 backdrop-blur-sm h-full w-full"
>
  <div class="relative mb-4 avatar-container">
    <div class="w-24 h-24 rounded-full overflow-hidden border-2 border-[#314aa9]/50 avatar-border transition-colors duration-300">
      <img 
        src={photo} 
        alt={name} 
        class="w-full h-full object-cover avatar-img transition-transform duration-500"
      />
    </div>
  </div>

  <h3 class="text-xl font-bold text-white name-text transition-colors duration-300 mb-1">
    {name}
  </h3>
  <p class="text-gray-400 text-sm font-medium">
    {role}
  </p>
  
  <div class="mt-4 w-full">
    <a 
      href={profileUrl} 
      target="_blank" 
      rel="noopener noreferrer"
      class="w-full flex justify-center items-center gap-2 py-2 px-4 rounded-xl bg-[#4b6ef8]/10 border border-[#4b6ef8]/30 text-[#4b6ef8] hover:bg-[#4b6ef8] hover:text-white transition-all duration-300 text-xs font-bold uppercase tracking-wider"
    >
      Ver Perfil <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
    </a>
  </div>
</div>

<style>
  .member-card {
    will-change: transform, border-color, box-shadow;
  }

  /* Tablet & Desktop Hover Effects Only */
  @media (min-width: 768px) and (hover: hover) {
    .member-card:hover {
      border-color: #4b6ef8;
      box-shadow: 0 0 30px rgba(75, 110, 248, 0.2);
      transform: translateY(-4px);
    }
    
    .member-card:hover .avatar-border {
      border-color: #4b6ef8;
    }

    .member-card:hover .avatar-img {
      transform: scale(1.1);
    }

    .member-card:hover .name-text {
      color: #4b6ef8;
    }
  }
</style>
