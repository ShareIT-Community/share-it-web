---
import { ClientRouter } from "astro:transitions";
import Footer from "../components/Footer/Footer.astro";
import "../styles/globals.css";
import Header from "../components/Header/Header.astro";
import ogImage from "../../../assets/ogimage.png";

interface Props {
  title: string;
  showBackButton?: boolean;
  fullWidth?: boolean;
}

const { title, showBackButton = false, fullWidth = false } = Astro.props;

const ogImageUrl = new URL(ogImage.src, Astro.site || Astro.url.origin).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/share-it-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta
      name="description"
      content="Share IT es una comunidad de Discord que reúne a personas de toda índole y de habla hispana, que forman parte o aspiran a formar parte de la industria IT. Somos una comunidad unida por el deseo de aprender, compartir conocimientos y crecer juntos en el ámbito tecnológico."
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Share IT es una comunidad de Discord que reúne a personas de toda índole y de habla hispana, que forman parte o aspiran a formar parte de la industria IT. Somos una comunidad unida por el deseo de aprender, compartir conocimientos y crecer juntos en el ámbito tecnológico."
    />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(ogImage.width)} />
    <meta property="og:image:height" content={String(ogImage.height)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta
      property="twitter:description"
      content="Share IT es una comunidad de Discord que reúne a personas de toda índole y de habla hispana, que forman parte o aspiran a formar parte de la industria IT. Somos una comunidad unida por el deseo de aprender, compartir conocimientos y crecer juntos en el ámbito tecnológico."
    />
    <meta property="twitter:image" content={ogImageUrl} />

    <ClientRouter />
  </head>

  <body class="bg-gray-900 min-h-screen flex flex-col">
    <Header />

    <main class:list={["flex-grow pt-20", !fullWidth && "container mx-auto px-4 py-8 max-w-4xl"]}>
      {
        showBackButton && (
          <button
            onclick="javascript:history.back()"
            class="cursor-pointer group inline-flex items-center gap-2 mb-4 text-secondary hover:text-primary transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2 focus:ring-offset-gray-800 rounded-md px-3 py-2"
            aria-label="Go back to previous page"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 transform transition-transform duration-200 group-hover:-translate-x-1"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z"
                clip-rule="evenodd"
              />
            </svg>
            <span class="font-medium">Volver</span>
          </button>
        )
      }
      <slot />
    </main>
    <Footer />
  </body>
</html>
