<div id="particles-js" class="absolute inset-0 pointer-events-none select-none"></div>

<script>
	import { particlesConfig } from './particles-config';

	function runParticles() {
		const el = document.getElementById('particles-js');
		if (!el || !window.particlesJS) return;
		window.particlesJS('particles-js', particlesConfig);
	}

	function scheduleParticles() {
		const load = () => {
			void import('particles.js').then(runParticles);
		};
		if ('requestIdleCallback' in window) {
			requestIdleCallback(load, { timeout: 3500 });
		} else {
			setTimeout(load, 200);
		}
	}

	document.addEventListener('astro:page-load', scheduleParticles);
	scheduleParticles();
</script>

<style>
	#particles-js {
		position: absolute;
		width: 100%;
		height: 100%;
		z-index: 0;
	}
</style>
