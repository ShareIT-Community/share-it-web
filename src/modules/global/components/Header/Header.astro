---
import { Image } from 'astro:assets'
import Logo from 'public/images/shareit_logo_waves.png'
import MobileMenu from 'src/modules/global/components/MobileMenu/MobileMenu.astro'
import { JoinButton } from './JoinButton'
import '@fontsource/josefin-sans'

const navItems = [
  { href: '/', text: 'Inicio' },
  { href: '/community', text: 'Comunidad' },
  { href: '/aboutUs', text: 'Sobre nosotros' },
]

const currentPath = Astro.url.pathname
---

<header class='fixed top-0 left-0 right-0 z-50 p-4 transition-all duration-300'>
  <nav
    class='container mx-auto px-4 max-w-6xl flex items-center justify-between'
  >
    <a
      href='/'
      class='font-bold text-white text-xl inline-flex items-center gap-2 group'
    >
      <Image
        src={Logo}
        alt='ShareIT Logo'
        class='w-8 h-8 transition-transform group-hover:scale-110'
      />
      <span class='font-josefin-sans tracking-tight'>ShareIT</span>
    </a>

    <ul class='flex gap-8 items-center' id='menu'>
      {
        navItems.map((item) => (
          <li class='md:flex hidden'>
            <a
              href={item.href}
              class:list={[
                `relative font-medium transition-all duration-300 py-1 before:content-[""] before:absolute before:bottom-0 before:left-0 before:right-0 before:h-[2px] before:bg-[#00e5ff] before:transition-all before:duration-300`,
                currentPath === item.href ||
                (item.href !== '/' && currentPath.startsWith(item.href))
                  ? `text-[#00e5ff] before:scale-x-100`
                  : `text-gray-300 hover:text-white before:scale-x-0 hover:before:scale-x-100`,
              ]}
            >
              {item.text}
            </a>
          </li>
        ))
      }

      <li class='hidden md:flex'>
        <JoinButton client:load />
      </li>
    </ul>

    <MobileMenu navItems={navItems} />
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid transparent;
  }

  .scrolled {
    background: rgba(10, 15, 29, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
</style>

<script>
  document.addEventListener('scroll', () => {
    const header = document.querySelector('header')
    if (header && window.scrollY > 0) {
      header.classList.add('scrolled')
    } else if (header) {
      header.classList.remove('scrolled')
    }
  })
</script>
