---
import type { GroupReferent } from '../interfaces/group-referent.interface'
import ReferentProfileModals from './ReferentProfileModals.astro'

interface Props {
	title: string
	description: string | string[]
	icon: string
	image?: string
	color?: string
	index: number
	referents?: GroupReferent[]
}

const { title, description, icon, image, color = 'primary', index, referents } =
	Astro.props

const descriptionIsMultiline = Array.isArray(description)
const descriptionText = descriptionIsMultiline
	? description.join('\n\n')
	: description

const cardUid = `wg-${index}`
---

<div class='discord-card-root relative h-full'>
	<div
		class='group/card relative flex flex-col gap-6 p-6 rounded-3xl bg-[#0a0f1d]/60 border border-white/5 backdrop-blur-md transition-all duration-500 hover:shadow-[0_0_40px_rgba(0,229,255,0.06)] hover:-translate-y-1 overflow-hidden h-full'
		style={`animation-delay: ${index * 100}ms`}
	>
		<div
			class='absolute -top-10 -left-10 w-32 h-32 bg-[#00e5ff]/5 rounded-full blur-2xl group-hover/card:bg-[#00e5ff]/10 transition-colors'
		>
		</div>

		<div class='flex items-center gap-4 relative z-10'>
			{
				image && (
					<div class='w-16 h-16 rounded-2xl overflow-hidden shrink-0 border border-white/10 group-hover/card:border-[#00e5ff]/50 transition-all duration-500 group-hover/card:scale-105 group-hover/card:shadow-[0_0_20px_rgba(0,229,255,0.2)]'>
						<img
							src={image}
							alt={title}
							class='w-full h-full object-cover'
						/>
					</div>
				)
			}
			<div class='flex flex-col'>
				<div class='flex items-center gap-2 px-1'>
					<h3
						class='text-2xl font-bold text-white group-hover/card:text-[#00e5ff] transition-colors leading-tight'
					>
						{title}
					</h3>
				</div>
				<div
					class='text-[10px] text-gray-500 font-bold px-1 flex items-center gap-2 mt-1 tracking-widest'
				>
					<span
						class='w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)] animate-pulse'
					></span>
					<span
						class='group-hover/card:text-emerald-400 transition-colors uppercase'
						>Grupo Activo</span
					>
				</div>
			</div>
		</div>

		<div
			class='relative p-6 rounded-2xl text-md leading-relaxed bg-white/5 border border-white/5 group-hover/card:border-white/10 transition-all duration-500 flex-grow flex flex-col'
		>
			<div
				class='absolute top-4 right-4 text-white/10 text-3xl opacity-0 group-hover/card:opacity-100 transition-opacity'
			>
				<i class='fa-solid fa-quote-right'></i>
			</div>

			<p
				class:list={[
					'text-gray-300 leading-relaxed italic group-hover/card:text-white transition-colors flex-grow [text-wrap:pretty]',
					{ 'whitespace-pre-line': descriptionIsMultiline },
				]}
			>
				"{descriptionText}"
			</p>

			{
				referents && referents.length > 0 && (
					<div class='mt-6 pt-5 border-t border-white/10 relative z-10'>
						<p class='text-[10px] text-gray-500 font-bold uppercase tracking-widest mb-3'>
							Referentes
						</p>
						<ul class='referent-avatars flex flex-wrap gap-2 list-none p-0 m-0'>
							{referents.map((r) => {
								const dlgId = `referent-dlg-${cardUid}-${r.id}`
								return (
									<li class='relative'>
										<div class='group/ref relative inline-flex flex-col items-center'>
											<button
												type='button'
												class='referent-open-btn relative rounded-full border-2 border-[#f97316] bg-[#1f2937] overflow-hidden w-10 h-10 shrink-0 cursor-pointer transition hover:brightness-110 hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#00e5ff] focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a0f1d]'
												aria-haspopup='dialog'
												aria-controls={dlgId}
												aria-label={`Ver perfil de ${r.nombre}`}
												data-referent-open={dlgId}
											>
												<img
													src={r.image}
													alt=''
													class='w-full h-full object-cover'
													width='40'
													height='40'
												/>
											</button>
											<span
												class='referent-popover pointer-events-none absolute left-1/2 top-[calc(100%+8px)] z-30 -translate-x-1/2 rounded-md border border-white/10 bg-[#0d1117] px-2.5 py-1.5 text-xs font-medium text-white opacity-0 shadow-lg transition-opacity duration-150 invisible group-hover/ref:opacity-100 group-hover/ref:visible group-focus-within/ref:opacity-100 group-focus-within/ref:visible whitespace-nowrap'
												role='tooltip'
											>
												{r.nombre}
											</span>
										</div>
									</li>
								)
							})}
						</ul>
					</div>
				)
			}
		</div>
	</div>

	{
		referents && referents.length > 0 && (
			<ReferentProfileModals referents={referents} cardUid={cardUid} />
		)
	}
</div>
