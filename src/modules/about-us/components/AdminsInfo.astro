---
import { admins } from 'src/modules/about-us/constants/about-us.const'
import { SocialLinks } from 'src/modules/about-us/components/CarouselAdmin/CustomLinks'
---

<section class='py-16 md:py-24'>
  <div class='max-w-5xl mx-auto px-6'>
    <h2 class='text-4xl font-bold text-white mb-16 text-center'>
      <span class='section-heading__accent_doble'>Conoce</span> a los líderes de nuestra
      <span class='text-[#00e5ff]'>Comunidad</span>
    </h2>

    <div class='grid gap-10'>
      {
        admins.map((admin) => (
          <div class='group relative overflow-hidden rounded-3xl border border-white/5 bg-[#0a0f1d]/60 backdrop-blur-md p-6 md:p-8 flex flex-col md:flex-row gap-8 items-center md:items-stretch transition-all duration-500 hover:shadow-[0_0_50px_rgba(0,229,255,0.08)] hover:-translate-y-1'>
            <div class='absolute -right-20 -bottom-20 w-64 h-64 bg-[#00e5ff]/5 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity' />

            <div class='w-full md:w-72 shrink-0 flex flex-col items-center justify-center border-b md:border-b-0 md:border-r border-white/5 pb-8 md:pb-0 md:pr-8'>
              <div class='relative mb-6'>
                <img
                  src={admin.avatar}
                  alt={admin.name}
                  class='w-36 h-36 rounded-full object-cover shadow-2xl transition-transform duration-500 group-hover:scale-105'
                />
              </div>

              <div class='text-center space-y-2'>
                <h3 class='text-2xl font-bold text-white tracking-tight group-hover:text-[#00e5ff] transition-colors'>
                  {admin.name}
                </h3>
                <p class='text-sm font-bold uppercase tracking-[0.2em] text-[#ff6900]/80'>
                  {admin.role}
                </p>
                <p class='text-gray-500 text-sm leading-snug px-2'>
                  {admin.about}
                </p>

                <div class='pt-4'>
                  <SocialLinks
                    github={admin.github}
                    linkedin={admin.linkedin}
                    website={admin.website}
                    twitter={admin.twitter}
                    instagram={admin.instagram}
                    className='flex gap-5 justify-center'
                  />
                </div>
              </div>
            </div>

            <div class='flex-1 flex flex-col justify-center space-y-5 py-4'>
              {admin.description?.map((paragraph) => (
                <p class='text-gray-400 leading-relaxed text-lg [text-wrap:pretty]'>
                  {paragraph}
                </p>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
